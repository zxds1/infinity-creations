rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function productExists(productId) {
      return isValidId(productId)
        && exists(/databases/$(database)/documents/products/$(productId));
    }

    // User Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'role'])
      );

      function isValidUser(user) {
        return user.uid == request.auth.uid 
          && user.email is string 
          && user.email.size() <= 256;
      }
    }

    // Design Requests Rules
    match /designRequests/{requestId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId) && isValidDesignRequest(request.resource.data);
      allow update: if false; // Design requests are immutable once generated for history
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidDesignRequest(req) {
        return req.userId == request.auth.uid
          && req.mediaCount is int
          && req.mediaCount >= 1
          && req.mediaCount <= 12
          && req.recommendations is string
          && req.recommendations.size() <= 20000
          && req.createdAt == request.time;
      }
    }

    // Orders Rules
    match /orders/{orderId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Non-payment Requests Rules
    match /purchaseRequests/{requestId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'requested'
        && request.resource.data.type in ['print', 'furniture', 'jewelry', 'branding']
        && request.resource.data.createdAt == request.time;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Cart Rules
    match /cart/{itemId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && isValidCartItem(request.resource.data);
      allow update: if ((isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin())
        && request.resource.data.productId == resource.data.productId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'deliveryAddress', 'customNotes', 'updatedAt'])
        && (!('quantity' in request.resource.data) || (request.resource.data.quantity is int && request.resource.data.quantity >= 1 && request.resource.data.quantity <= 99));
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidCartItem(item) {
        return productExists(item.productId)
          && item.productName is string
          && item.productName.size() <= 160
          && (!('customNotes' in item) || (item.customNotes is string && item.customNotes.size() <= 2000))
          && item.price is number
          && item.price >= 0
          && item.quantity is int
          && item.quantity >= 1
          && item.quantity <= 99
          && item.createdAt == request.time;
      }
    }

    // Wishlist Rules
    match /wishlist/{itemId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && isValidWishlistItem(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidWishlistItem(item) {
        return productExists(item.productId)
          && item.productName is string
          && item.productName.size() <= 160
          && item.price is number
          && item.price >= 0
          && item.createdAt == request.time;
      }
    }

    // Behavior Events Rules
    match /events/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventType in ['view', 'compare', 'wishlist', 'cart', 'intent', 'analyzer', 'branding', 'checkout_started', 'payment_attempted', 'payment_success', 'payment_failed']
        && request.resource.data.createdAt == request.time;
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }

    match /sellerSignals/{signalId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }

    // Review Rules
    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonialSubmissions/{submissionId} {
      allow create: if isValidTestimonialSubmission(request.resource.data);
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();

      function isValidTestimonialSubmission(submission) {
        return submission.clientName is string
          && submission.clientName.size() >= 1
          && submission.clientName.size() <= 120
          && submission.quote is string
          && submission.quote.size() >= 1
          && submission.quote.size() <= 1200
          && (!('project' in submission) || (submission.project is string && submission.project.size() <= 160))
          && (!('beforeImage' in submission) || (submission.beforeImage is string && submission.beforeImage.size() <= 10000))
          && (!('afterImage' in submission) || (submission.afterImage is string && submission.afterImage.size() <= 10000))
          && submission.status == 'pending'
          && submission.userId is string
          && submission.userId.size() <= 128
          && submission.createdAt == request.time;
      }
    }

    // Configurable Catalog & Services
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if false; 
    }
  }
}
