rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mwirigib332@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'role'])
      );

      function isValidUser(user) {
        return user.uid == request.auth.uid 
          && user.email is string 
          && user.email.size() <= 256;
      }
    }

    // Design Requests Rules
    match /designRequests/{requestId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId) && isValidDesignRequest(request.resource.data);
      allow update: if false; // Design requests are immutable once generated for history
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidDesignRequest(req) {
        return req.userId == request.auth.uid
          && req.imageUrl is string && req.imageUrl.size() <= 2048
          && req.createdAt == request.time;
      }
    }

    // Orders Rules
    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId) && isValidOrder(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        // Allow user to cancel order if it's still pending
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled'
        && resource.data.status == 'pending'
      );

      function isValidOrder(order) {
        return order.userId == request.auth.uid
          && order.type in ['print', 'furniture', 'jewelry', 'branding']
          && order.createdAt == request.time
          && order.status == 'pending';
      }
    }

    // Cart Rules
    match /cart/{itemId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Wishlist Rules
    match /wishlist/{itemId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Review Rules
    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurable Catalog & Services
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
